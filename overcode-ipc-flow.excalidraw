      "fontSize": 14,
      "fontFamily": 5,
      "text": "ipcMain.handle「\n  'auth:connect',\n  async 「_, prov」\n」\n\nipcMain.handle「\n  'git:scan',\n  async 「_, dirs」\n」\n\nipcMain.handle「\n  'github:repos',\n  async 「」\n」\n\nipcMain.handle「\n  'gitlab:projects',\n  async 「」\n」\n\nipcMain.handle「\n  'ai:complete',\n  async 「_, s, u」\n」\n\nipcMain.handle「\n  'store:get',\n  async 「_, key」\n」\n\n+ 20 more",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ipcMain.handle「\n  'auth:connect',\n  async 「_, prov」\n」\n\nipcMain.handle「\n  'git:scan',\n  async 「_, dirs」\n」\n\nipcMain.handle「\n  'github:repos',\n  async 「」\n」\n\nipcMain.handle「\n  'gitlab:projects',\n  async 「」\n」\n\nipcMain.handle「\n  'ai:complete',\n  async 「_, s, u」\n」\n\nipcMain.handle「\n  'store:get',\n  async 「_, key」\n」\n\n+ 20 more",
